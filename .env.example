# ==== App Runtime ====
# Comma- or space-separated relay WebSocket URLs.
# Leave blank to use startup relay discovery.
# Example: ws://localhost:7447 wss://relay.example.com
VITE_DEFAULT_RELAYS=
# Optional Noas host/root URL for sign-in and sign-up.
# Nodex always uses `/.well-known/nostr.json` discovery from this host.
# Example: https://accounts.example.com
VITE_NOAS_HOST_URL=
# Optional top-of-app message banner.
VITE_NODEX_MOTD=
# Set `false` to hide guest identity sign-in.
VITE_ALLOW_GUEST_SIGN_IN=true
# Set `true` to show the built-in demo feed relay.
VITE_ENABLE_DEMO_FEED=false
# Enable in-browser image captioning.
VITE_LOCAL_CAPTIONS=true

# ==== Relay Discovery ====
# Comma-separated prefixes stripped from relay display names.
VITE_RELAY_COMMON_PREFIXES=feed,nostr,relay
# Comma-separated prefixes used for site-domain relay discovery.
# Falls back to `VITE_RELAY_COMMON_PREFIXES` when blank.
VITE_RELAY_DISCOVERY_PREFIXES=

# ==== NIP-96 Uploads ====
# NIP-96 upload endpoint used by attachment buttons.
VITE_NIP96_UPLOAD_URL=https://nostr.build/api/v2/upload/files
# Max upload size in bytes. Default: 104857600 (100 MiB).
VITE_NIP96_MAX_UPLOAD_BYTES=104857600
# Optional local Route96 stack for self-hosted uploads.
# Use with:
# docker compose -f docker-compose.yml -f docker-compose.upload.yml --profile upload ...
ROUTE96_IMAGE=voidic/route96:latest
ROUTE96_HTTP_PORT=8096
ROUTE96_DATABASE=route96
ROUTE96_DATABASE_USER=route96
ROUTE96_DATABASE_PASSWORD=route96
ROUTE96_DATABASE_ROOT_PASSWORD=route96root
# Local Route96 upload URL example:
# VITE_NIP96_UPLOAD_URL=http://localhost:${ROUTE96_HTTP_PORT}/api/v1/upload

# ==== Debug / Privacy ====
# Enable feature-level debug logs in production builds.
# Development builds already log these by default.
VITE_DEBUG_FEATURES=false
# Enable verbose attachment upload debug logs.
VITE_DEBUG_ATTACHMENTS=false
# Disable localStorage, sessionStorage, caches, and cookies.
# Can also be forced with `?nodexNoStorage=true`.
VITE_DISABLE_CLIENT_PERSISTENCE=false

# ==== Local Docker / Compose ====
# WebSocket port exposed by the bundled rnostr relay container.
RNOSTR_WS_PORT=7447
# Docker image used for the bundled rnostr relay container.
RNOSTR_IMAGE=fiatjaf/rnostr:latest
# HTTP port exposed by the Nodex web app container.
NODEX_HTTP_PORT=8080

RNOSTR_WS_PORT=7447
NODEX_HTTP_PORT=8080
RNOSTR_IMAGE=fiatjaf/rnostr:latest
# Managed NIP-96 upload endpoint (public default; may return 401/rate-limit depending on provider policy)
VITE_NIP96_UPLOAD_URL=https://nostr.build/api/v2/upload/files
# Comma-separated relay WebSocket URLs (e.g. ws://localhost:7447 for local Docker setup).
VITE_DEFAULT_RELAYS=
# Optional demo feed toggle (disabled by default). Set true to show local demo feed relay.
VITE_ENABLE_DEMO_FEED=false
# Optional auth toggle. Set false to hide guest identity sign-in from the auth modal.
VITE_ALLOW_GUEST_SIGN_IN=true

# Noas Authentication Server Defaults (optional)
VITE_NOAS_API_URL=

# Optional self-hosted NIP-96 stack (Route96 + MySQL), enabled with compose profile "upload"
ROUTE96_IMAGE=voidic/route96:latest
ROUTE96_HTTP_PORT=8096
ROUTE96_DATABASE=route96
ROUTE96_DATABASE_USER=route96
ROUTE96_DATABASE_PASSWORD=route96
ROUTE96_DATABASE_ROOT_PASSWORD=route96root
# When using self-hosted uploads locally, set this to:
# VITE_NIP96_UPLOAD_URL=http://localhost:${ROUTE96_HTTP_PORT}/api/v1/upload
